        "jsCode": "\nconst raw = $input.first().json;\n\nlet emailBody = '';\nif (raw.body && raw.body.text)       emailBody = raw.body.text;\nelse if (raw.text)                   emailBody = raw.text;\nelse if (raw.snippet)                emailBody = raw.snippet;\nelse if (raw.body && raw.body.html)  emailBody = raw.body.html.replace(/<[^>]*>/g, ' ').replace(/&nbsp;/g, ' ');\nelse throw new Error('Corpo do e-mail não encontrado.');\n\nfunction extrair(chave) {\n  const regex = new RegExp('^\\\\s*' + chave + '\\\\s*:\\\\s*(.*)$', 'mi');\n  const match = emailBody.match(regex);\n  return match ? match[1].trim() : null;\n}\n\nfunction toTitleCase(str) {\n  if (!str) return null;\n  return str.split(' ').filter(p => p.trim())\n    .map(w => w.charAt(0).toUpperCase() + w.slice(1).toLowerCase())\n    .join(' ');\n}\n\n// Campos exatos do e-mail Convenia\nconst nomeCompletoRaw  = extrair('COLABORADOR');\nconst dataAdmissao     = extrair('DATA ADMISS[ÃA]O') || extrair('DATA ADMISSAO');\nconst emailPessoal     = extrair('E-MAIL PESSOAL') || 'Nao informado';\nconst emailCorporativo = extrair('E-MAIL CORPORATIVO');\nconst departamento     = extrair('DEPARTAMENTO');\nconst gestorRaw        = extrair('GESTOR');\nconst telefone         = extrair('TELEFONE');\nconst jornada          = extrair('JORNADA') || '';\nconst equipamento      = extrair('Necessidade de equipamento') || 'Nao informado';\n\n// Nome\nconst partes       = nomeCompletoRaw ? nomeCompletoRaw.split(' ').filter(p => p.trim()) : [];\nconst primeiroNome = partes.length > 0 ? toTitleCase(partes[0]) : null;\nconst sobrenome    = partes.length > 1 ? toTitleCase(partes.slice(1).join(' ')) : '';\n\nconst usernameGoogle = emailCorporativo ? emailCorporativo.split('@')[0].toLowerCase().trim() : null;\nconst ehPresencial   = jornada.toUpperCase().includes('PRESENCIAL');\nconst chaveDepto     = departamento ? departamento.toUpperCase().trim() : '';\n\n// --- MAPA DE GESTORES ---\n// Cobre primeiro nome, nome completo e variações com/sem acento\nconst mapaGestores = {\n  // Gabriel Cunha\n  'GABRIEL':              'gabriel.cunha@raiobeneficios.com',\n  'GABRIEL CUNHA':        'gabriel.cunha@raiobeneficios.com',\n  // Ricardo Reis\n  'RICARDO':              'ricardo.reis@raiobeneficios.com',\n  'RICARDO REIS':         'ricardo.reis@raiobeneficios.com',\n  // Amanda Pereira (Cabreira)\n  'AMANDA':               'amanda.pereira@raiobeneficios.com',\n  'AMANDA PEREIRA':       'amanda.pereira@raiobeneficios.com',\n  'AMANDA CABREIRA':      'amanda.pereira@raiobeneficios.com',\n  // Lucca\n  'LUCCA':                'lucca@raiobeneficios.com',\n  // Pietro\n  'PIETRO':               'pietro@raiobeneficios.com',\n  // Gustavo Lima\n  'GUSTAVO':              'gustavo.lima@raiobeneficios.com',\n  'GUSTAVO LIMA':         'gustavo.lima@raiobeneficios.com',\n  // Pedro Petersen\n  'PEDRO':                'pedro.petersen@raiobeneficios.com',\n  'PEDRO PETERSEN':       'pedro.petersen@raiobeneficios.com',\n  // Veronica Abdala\n  'VERONICA':             'veronica.abdala@raiobeneficios.com',\n  'VERÔNICA':             'veronica.abdala@raiobeneficios.com',\n  'VERONICA ABDALA':      'veronica.abdala@raiobeneficios.com',\n  'VERÔNICA ABDALA':      'veronica.abdala@raiobeneficios.com',\n  // Mateus Jarros\n  'MATEUS':               'mateus.jarros@raiobeneficios.com',\n  'MATEUS JARROS':        'mateus.jarros@raiobeneficios.com',\n  // Christiano Almeida\n  'CHRISTIANO':           'christiano.almeida@raiobeneficios.com',\n  'CHRISTIANO ALMEIDA':   'christiano.almeida@raiobeneficios.com'\n};\n\nconst gestorChave  = gestorRaw ? gestorRaw.toUpperCase().trim() : '';\nconst gestorEmail  = mapaGestores[gestorChave] || gestorRaw || 'nao-identificado';\n\n// Grupos\nconst mapaGrupos = {\n  COMERCIAL:  'comercial@raiobeneficios.com',\n  RH:         'rh@raiobeneficios.com',\n  FINANCEIRO: 'financeiro@raiobeneficios.com',\n  TECH:       'tech@raiobeneficios.com',\n  TI:         'tech@raiobeneficios.com',\n  OPERACOES:  'operacoes@raiobeneficios.com',\n  MARKETING:  'marketing@raiobeneficios.com'\n};\n\nconst todosOsGrupos = ['todos@raiobeneficios.com'];\nif (ehPresencial) todosOsGrupos.push('sede-poa@raiobeneficios.com');\nconst grupoDepto = mapaGrupos[chaveDepto];\nif (grupoDepto) todosOsGrupos.push(grupoDepto);\n\nconst mapaDrives = {\n  COMERCIAL:  'PLACEHOLDER_DRIVE_COMERCIAL',\n  RH:         'PLACEHOLDER_DRIVE_RH',\n  FINANCEIRO: 'PLACEHOLDER_DRIVE_FINANCEIRO',\n  TECH:       'PLACEHOLDER_DRIVE_TECH',\n  TI:         'PLACEHOLDER_DRIVE_TECH'\n};\n\nreturn [{\n  json: {\n    dadosDoColaborador: {\n      nomeCompleto:     toTitleCase(nomeCompletoRaw),\n      primeiroNome,\n      sobrenome,\n      emailCorporativo: emailCorporativo ? emailCorporativo.toLowerCase().trim() : null,\n      emailPessoal,\n      usernameGoogle,\n      dataAdmissao,\n      departamento,\n      chaveDepto,\n      jornada,\n      ehPresencial,\n      gestorRaw,\n      gestorEmail,\n      telefone,\n      equipamento,\n      idDriveDestino: mapaDrives[chaveDepto] || 'PLACEHOLDER_DRIVE_GERAL',\n      todosOsGrupos,\n      ehComercial: chaveDepto === 'COMERCIAL'\n    }\n  }\n}];\n"
      },
