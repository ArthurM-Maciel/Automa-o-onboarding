    {
      "parameters": {
        "jsCode": "// Acessa os dados de entrada de forma segura (funciona para Texto ou HTML)\nconst inputData = $input.first().json;\n\nlet emailBody = '';\n\n// 1. TENTA PEGAR O TEXTO LIMPO, SE NÃO TIVER, PEGA O SNIPPET (RESUMO) OU HTML\nif (inputData.body && inputData.body.text) {\n  emailBody = inputData.body.text;\n} else if (inputData.text) {\n  emailBody = inputData.text;\n} else if (inputData.snippet) {\n  emailBody = inputData.snippet;\n} else if (inputData.html) {\n  emailBody = inputData.html.replace(/<[^>]*>/g, ' ').replace(/&nbsp;/g, ' ');\n} else {\n  throw new Error(\"O e-mail parece vazio ou o formato mudou. Verifique o Input.\");\n}\n\n// --- FUNÇÃO AUXILIAR PARA \"Title Case\" ---\nfunction toTitleCase(str) {\n  if (!str) return null;\n  return str\n    .split(' ')\n    .filter(p => p.trim() !== '')\n    .map(word =>\n      word.charAt(0).toUpperCase() + word.slice(1).toLowerCase()\n    )\n    .join(' ');\n}\n\n// --- FUNÇÃO DE EXTRAÇÃO GENÉRICA ---\nfunction extrairValor(chave) {\n  const regex = new RegExp('^\\\\s*' + chave + '\\\\s*:\\\\s*(.*)$', 'mi');\n  const match = emailBody.match(regex);\n  return match ? match[1].trim() : null;\n}\n\n// --- EXTRAÇÃO DOS DADOS ---\nconst nomeCompletoRaw = extrairValor('COLABORADOR');\nconst emailCorporativo = extrairValor('E-MAIL CORPORATIVO');\nconst emailPessoal = extrairValor('E-MAIL PESSOAL');\nconst dataAdmissao =\n  extrairValor('DATA DE ADMISSÃO') ||\n  extrairValor('DATA ADMISSAO') ||\n  extrairValor('DATA ADMISSÃO');\nconst departamento = extrairValor('DEPARTAMENTO');\nconst gestor = extrairValor('GESTOR');\nconst telefone = extrairValor('TELEFONE');\nconst jornada = extrairValor('JORNADA') || \"\";\n\n// --- LÓGICA DE REGIME DE TRABALHO (SEDE POA) ---\n// Se não encontrar a palavra \"REMOTO\", assume que é presencial/híbrido\nconst ehRemoto = jornada.toUpperCase().includes(\"REMOTO\");\n\nlet primeiroNome = null;\nlet sobrenome = null;\n\n// --- TRATAMENTO DE NOME ---\nif (nomeCompletoRaw) {\n  const partesNome = nomeCompletoRaw\n    .split(' ')\n    .filter(p => p.trim() !== '');\n  if (partesNome.length > 0) {\n    primeiroNome = toTitleCase(partesNome[0]);\n    if (partesNome.length > 1) {\n      sobrenome = toTitleCase(partesNome.slice(1).join(' '));\n    } else {\n      sobrenome = '';\n    }\n  }\n}\n\n// --- GERAÇÃO DO USERNAME (LOGIN) ---\nlet usernameGoogle = null;\nif (emailCorporativo) {\n  usernameGoogle = emailCorporativo.split('@')[0].toLowerCase().trim();\n}\n\n// --- MAPEAMENTO DE DRIVES POR DEPARTAMENTO ---\nconst mapaDeDrives = {\n  COMERCIAL: 'ID_DA_PASTA_COMERCIAL',\n  RH: 'ID_DA_PASTA_RH',\n  FINANCEIRO: 'ID_DA_PASTA_FINANCEIRO',\n  TI: 'ID_DA_PASTA_TI',\n  TECH: 'ID_DA_PASTA_TI'\n};\n\n// --- MAPEAMENTO DE GRUPOS DE E-MAIL ---\nconst mapaDeGrupos = {\n  COMERCIAL: 'comercial@raiobeneficios.com',\n  RH: 'rh@raiobeneficios.com',\n  FINANCEIRO: 'financeiro@raiobeneficios.com',\n  TECH: 'tech@raiobeneficios.com',\n  TI: 'tech@raiobeneficios.com'\n};\n\n// Normaliza o texto do departamento\nconst chaveDepto = departamento ? departamento.toUpperCase().trim() : '';\n\n// 1. Define o grupo do setor (ou geral se não encontrar)\nconst emailGrupoSetor = mapaDeGrupos[chaveDepto] || 'geral@raiobeneficios.com';\n\n// 2. Monta a lista de todos os grupos que o colaborador deve entrar\nlet listaFinalGrupos = ['03hv69ve2q9hx18', emailGrupoSetor]; // Geral Raiô + Grupo do Setor\n\n// 3. Adiciona sede-poa se NÃO for remoto\nif (!ehRemoto) {\n  listaFinalGrupos.push('sede-poa@raiobeneficios.com');\n}\n\n// --- RETORNO NO FORMATO ESPERADO PELO n8n ---\nreturn [\n  {\n    json: {\n      dadosDoColaborador: {\n        nomeCompleto: toTitleCase(nomeCompletoRaw),\n        primeiroNome,\n        sobrenome,\n        emailCorporativo: emailCorporativo\n          ? emailCorporativo.toLowerCase().trim()\n          : null,\n        emailPessoal: emailPessoal ? emailPessoal.trim() : 'Nao informado',\n        usernameGoogle,\n        dataAdmissao,\n        departamento,\n        jornada,\n        ehRemoto,\n        gestor,\n        telefone,\n        idDriveDestino: mapaDeDrives[chaveDepto] || 'ID_PASTA_PADRAO',\n        emailGrupoDestino: emailGrupoSetor,\n        todosOsGrupos: listaFinalGrupos // Use esta lista para automatizar as entradas\n      },\n    },\n  },\n];"
      },
