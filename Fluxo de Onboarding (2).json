    {
      "parameters": {
        "jsCode": "// Gera senha segura: letra maiúscula + minúsculas + números + símbolo\n// Formato: Rb + 8 chars aleatórios + !9  →  ex: RbxK9mTq2a!9\nconst chars = 'abcdefghijkmnpqrstuvwxyzABCDEFGHJKLMNPQRSTUVWXYZ23456789';\nlet senha = 'Rb';\nfor (let i = 0; i < 8; i++) {\n  senha += chars.charAt(Math.floor(Math.random() * chars.length));\n}\nsenha += '!9';\n\nconst dados = $('Parsear Dados do Convenia').item.json.dadosDoColaborador;\n\nreturn [{\n  json: {\n    ...dados,\n    senhaTemporaria: senha\n  }\n}];"
      },
